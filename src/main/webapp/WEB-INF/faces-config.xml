<?xml version="1.0" encoding="UTF-8"?>
<faces-config
        xmlns="http://xmlns.jcp.org/xml/ns/javaee"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee http://xmlns.jcp.org/xml/ns/javaee/web-facesconfig_2_3.xsd"
        version="2.3">

    <application>
        <!--
        Configuració de l'idioma per defecte, i llista d'idiomes soportats.
        -->
        <locale-config>
            <default-locale>ca</default-locale>
            <supported-locale>es</supported-locale>
            <supported-locale>en</supported-locale>
        </locale-config>

        <!--coger el paquete de textos definido en la common-->
        <resource-bundle>
            <base-name>i18n.text</base-name>
            <var>text</var>
        </resource-bundle>

        <!--definir paquete de errores de validacion de la commons-->
        <message-bundle>i18n.ValidationMessages</message-bundle>
    </application>
    <application>
        <el-resolver>org.primefaces.application.exceptionhandler.PrimeExceptionHandlerELResolver</el-resolver>
    </application>
    <factory>
        <exception-handler-factory>org.primefaces.application.exceptionhandler.PrimeExceptionHandlerFactory</exception-handler-factory>
    </factory>
</faces-config>